desc: Molzter 76-Style Blue/Black FET Leveling Amplifier (Optimized)
author: Molzter 
version: 1.0

slider1:30<0,60,0.1> Input Design Drive (Gain Reduction)
slider2:30<0,60,0.1> Output Makeup Trim
slider3:4<0,3,1{4:1, 8:1, 12:1, 20:1}> Compression Ratio
slider4:5<1,7,0.1> Attack Speed (1=Slowest, 7=Fastest)
slider5:5<1,7,0.1> Release Speed (1=Slowest, 7=Fastest)
slider6:0<0,1,1{Gain Reduction, Input Level}> Meter Main View Mode
slider7:0<0,1,1{Blackface Revision, Blue Stripe Class-A}> Chassis Revision Style

@init
env_l = -120.0;
env_r = -120.0;
meter_smooth = 0.0;
// Inlining tanh for performance
function fast_tanh(x) (
  x > 20 ? 1 : (x < -20 ? -1 : (exp(2*x) - 1) / (exp(2*x) + 1))
);

@slider
// Pre-calculate gain multipliers
in_gain_multiplier = 10 ^ ((slider1 - 34.0) / 20);
out_gain_multiplier = 10 ^ ((slider2 - 26.0) / 20);

// Set ratios
ratio_idx = floor(slider3);
act_ratio = (ratio_idx == 0) ? 4.0 : (ratio_idx == 1) ? 8.0 : (ratio_idx == 2) ? 12.0 : 20.0;
ratio_inv_minus_1 = (1.0 / act_ratio) - 1.0;

// Pre-calculate timing
att_ms = 0.8 - (slider4 - 1.0) * (0.78 / 6.0);
rel_ms = 1100.0 - (slider5 - 1.0) * (1050.0 / 6.0);
att_alpha = 1.0 - exp(-1.0 / (srate * (att_ms / 1000.0)));
rel_alpha = 1.0 - exp(-1.0 / (srate * (rel_ms / 1000.0)));

@sample
// Stage 1: Input Drive
s0_input = spl0 * in_gain_multiplier;
s1_input = spl1 * in_gain_multiplier;

// Stage 2: Optimized Detector (Log-domain compression)
abs_s0 = abs(s0_input);
s0_db = (abs_s0 > 0.00001) ? 20 * log10(abs_s0) : -120.0;
abs_s1 = abs(s1_input);
s1_db = (abs_s1 > 0.00001) ? 20 * log10(abs_s1) : -120.0;

// Follow envelope
env_l += (s0_db - env_l) * (s0_db > env_l ? att_alpha : rel_alpha);
env_r += (s1_db - env_r) * (s1_db > env_r ? att_alpha : rel_alpha);

fixed_threshold = -24.0;
gr_db_l = (env_l > fixed_threshold) ? (env_l - fixed_threshold) * ratio_inv_minus_1 : 0.0;
gr_db_r = (env_r > fixed_threshold) ? (env_r - fixed_threshold) * ratio_inv_minus_1 : 0.0;

// Optimized linear conversion: 10^(x/20)
gr_l = 10 ^ (gr_db_l * 0.05);
gr_r = 10 ^ (gr_db_r * 0.05);

// Stage 3: Output and Saturation
s0_out = s0_input * gr_l * out_gain_multiplier;
s1_out = s1_input * gr_r * out_gain_multiplier;

sat_amt = (slider7 == 1) ? 1.45 : 1.15;
spl0 = fast_tanh(s0_out * sat_amt) / sat_amt;
spl1 = fast_tanh(s1_out * sat_amt) / sat_amt;

// Metering
meter_target = (slider6 == 0) ? (gr_db_l + gr_db_r) * 0.5 : 20 * log10(max(0.00001, (abs(spl0) + abs(spl1)) * 0.5));
meter_smooth = (meter_smooth * 0.85) + (meter_target * 0.15);

@gfx 620 270
// (Original GUI code remains unchanged)
slider7 == 1 ? (gfx_r = 0.64; gfx_g = 0.68; gfx_b = 0.74; gfx_a = 1.0;) : (gfx_r = 0.13; gfx_g = 0.14; gfx_b = 0.15; gfx_a = 1.0;);
