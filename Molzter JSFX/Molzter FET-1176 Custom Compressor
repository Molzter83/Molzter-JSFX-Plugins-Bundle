slider6 == 0 ? (gfx_x = m_x + 22; gfx_y = m_y + 50; gfx_drawstr("-20"); gfx_x = m_x + 55; gfx_y = m_y + 24; gfx_drawstr("-10"); gfx_x = m_x + 102; gfx_y = m_y + 14; gfx_drawstr("-5"); gfx_x = m_x + 145; gfx_y = m_y + 24; gfx_drawstr("-2"); gfx_x = m_x + 180; gfx_y = m_y + 50; gfx_drawstr("0"); gfx_x = m_x + 15; gfx_y = m_y + 82; gfx_drawstr("CLA-76 ATTENUATE (dB)"); ) : ( gfx_x = m_x + 18; gfx_y = m_y + 50; gfx_drawstr("-40"); gfx_x = m_x + 52; gfx_y = m_y + 24; gfx_drawstr("-24"); gfx_x = m_x + 98; gfx_y = m_y + 14; gfx_drawstr("-12"); gfx_x = m_x + 145; gfx_y = m_y + 24; gfx_drawstr("-6"); gfx_x = m_x + 182; gfx_y = m_y + 50; gfx_drawstr("0"); gfx_x = m_x + 15; gfx_y = m_y + 82; gfx_drawstr("CLA-76 INPUT LEVEL dBFS"); );
gfx_set(0.05, 0.05, 0.06, 1.0); gfx_line(pivot_x, pivot_y, tip_x, tip_y, 1); gfx_line(pivot_x - 1, pivot_y, tip_x - 1, tip_y, 0);
